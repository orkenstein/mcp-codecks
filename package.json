{
  "name": "codecks-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Codecks game project tracker API integration",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc && mkdir -p dist/schemas && cp src/schemas/codecks-api-schema.json dist/schemas/codecks-api-schema.json",
    "clean": "rm -rf dist",
    "generate:schema": "node scripts/generate-api-schema.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src tests --ext .ts",
    "eval": "node scripts/run-evaluation.mjs",
    "eval:verbose": "node scripts/run-evaluation.mjs --verbose"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitest/coverage-v8": "^2.1.4",
    "axios-mock-adapter": "^1.22.0",
    "eslint": "^9.39.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.4",
    "xml2js": "^0.6.2"
  }
}
